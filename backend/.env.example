POSTGRES_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/sutra

# Control plane -> host manager settings
SUTRA_RUNTIME_API_KEY=change-me
GCP_RUNTIME_HOST_INSTANCE_NAME=sutra-firecracker-host
GCP_RUNTIME_HOST_API_OVERRIDE_BASE_URL=http://127.0.0.1:8787

# Host manager / runtime infra settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_COMPUTE_ZONE=us-central1-a
BASE_ROOTFS_PATH=/opt/sutra/base-rootfs.ext4
KERNEL_PATH=/opt/sutra/vmlinux
FC_BINARY=/usr/local/bin/firecracker
JAILER_BINARY=/usr/local/bin/jailer
AGENTS_DIR=/var/agents
VCPU_COUNT=1
MEM_SIZE_MIB=512
AGENT_DISK_SIZE_GB=20
AGENT_DISK_TYPE=pd-balanced
DEVICE_WAIT_TIMEOUT_S=60
GUEST_API_PORT=8642
